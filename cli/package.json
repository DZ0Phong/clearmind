{
  "name": "clearmind-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Chạy ngầm Clearmind với system tray + auto-start trên Windows. Lưu data ra %APPDATA%/Clearmind/.",
  "bin": {
    "clearmind": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "tray": "node cli.js --tray",
    "dev": "node cli.js --no-tray"
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "systray2": "^2.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
